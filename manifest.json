{
  "manifest_version": 3,
  "name": "Shopify Compliance Tool",
  "version": "1.0.0",
  "description": "Shopify 合规信息自动化工具",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "page-inject.js",
        "config/*.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}